{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "calligro",
  "mainBinaryName": "calligro",
  "version": "../package.json",
  "identifier": "com.ideasalmanac.calligro",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Calligro",
        "width": 1310,
        "height": 850,
        "resizable": true,
        "fullscreen": false,
        "url": "/webapp.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
